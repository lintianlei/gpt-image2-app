{
  "name": "gpt-image2",
  "version": "1.0.0",
  "description": "GPT IMAGE2 - AI Image Generation App",
  "main": "index.html",
  "scripts": {
    "dev": "npx serve .",
    "build": "mkdir -p www && cp index.html sw.js manifest.json www/ 2>/dev/null; cp -r icons www/ 2>/dev/null; echo 'Build complete'",
    "cap:sync": "npx @capacitor/cli sync",
    "cap:open:android": "npx @capacitor/cli open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/share": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "serve": "^14.2.0"
  }
}
